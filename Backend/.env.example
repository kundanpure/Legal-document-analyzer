# --- Google Cloud Configuration ---
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_API_KEY=your-gemini-api-key
GCS_BUCKET_NAME=your-gcs-bucket-name
DOCUMENT_AI_LOCATION=your-document-ai-location-e.g.-us
DOCUMENT_AI_PROCESSOR_ID=your-document-ai-processor-id

# --- Authentication (Service Account) ---
# Path to your JSON key file (e.g., ./gcp-key.json)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json

# --- Database Configuration ---
DATABASE_URL=sqlite+aiosqlite:///./legalmind.db

# --- Security & Auth (For future use) ---
SECRET_KEY=generate-a-long-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Server Settings ---
ENVIRONMENT=development
PORT=8000
DEBUG=True
